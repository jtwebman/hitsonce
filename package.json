{
  "name": "hitsonce",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "migrate": "wrangler d1 migrations apply hitsonce --remote",
    "migrate:local": "wrangler d1 migrations apply hitsonce --local"
  },
  "dependencies": {
    "@hono/zod-validator": "0.8.0",
    "hono": "4.12.25",
    "isbot": "5.1.43",
    "jose": "6.2.3",
    "ua-parser-js": "2.0.10",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260617.1",
    "@eslint/js": "10.0.1",
    "@types/better-sqlite3": "7.6.13",
    "better-sqlite3": "12.11.1",
    "eslint": "10.5.0",
    "globals": "17.6.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9",
    "wrangler": "4.102.0"
  }
}
